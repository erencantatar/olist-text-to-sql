# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Optional: only needed to use OpenRouter (cloud) models instead of local Ollama.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: override the default local model used by the MCP server / eval.
